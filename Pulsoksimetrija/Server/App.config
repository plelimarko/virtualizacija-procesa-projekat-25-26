<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="StreamingBinding" 
                 transferMode="Buffered" 
                 maxReceivedMessageSize="20971520">
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>

    <services>
      <service name="Server.EcgService">
        <endpoint address="net.tcp://localhost:4000/EcgService"
                  binding="netTcpBinding"
                  bindingConfiguration="StreamingBinding"
                  contract="Common.IEcgService" />
      </service>
    </services>
  </system.serviceModel>

	<appSettings>
		<add key="HrMaxThreshold" value="100"/>
		<add key="EcgSpikeThreshold" value="500"/>
	</appSettings>
</configuration>